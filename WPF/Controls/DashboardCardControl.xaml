<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="WPF.Controls.DashboardCardControl"
             d:DesignWidth="59.332">

    <Border Margin="8"
            Padding="16"
            CornerRadius="10"
            BorderBrush="#DADADA"
            BorderThickness="1"
            Background="White">

        <StackPanel HorizontalAlignment="Center">

            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>

            <TextBlock Margin="0,12,0,0"
                       Text="{Binding Value, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

        </StackPanel>

    </Border>

</UserControl>