<UserControl x:Class="WPF.Controls.DashboardCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <materialDesign:Card Margin="0,0,8,8"
                         Padding="16"
                         materialDesign:ElevationAssist.Elevation="Dp1">
        <StackPanel>
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                       Margin="0,6,0,0"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Foreground="{StaticResource TextPrimaryBrush}" />
        </StackPanel>
    </materialDesign:Card>
</UserControl>
