<UserControl x:Class="WPF.Views.InvoiceDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding Invoice, Converter={StaticResource ObjectToVisibilityConverter}}">
            <StackPanel>
                <materialDesign:Card Padding="16"
                                     Margin="0,0,0,12"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Invoice.InvoiceId, StringFormat='{}Invoice #{0}'}"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding Invoice.CustomerName}"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Invoice.Status}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding Invoice.CreateDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Booking"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding Invoice.BookingId, StringFormat='{}#{0}'}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding Invoice.BookingStatus}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Customer"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding Invoice.CustomerPhone, TargetNullValue='No phone'}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding Invoice.CustomerEmail, TargetNullValue='No email'}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Created by"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding Invoice.CreatedByUserName}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding Invoice.Note, TargetNullValue='No note'}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Padding="16"
                                     Margin="0,0,0,12"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
                    <UniformGrid Columns="4">
                        <StackPanel>
                            <TextBlock Text="Room"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding Invoice.RoomAmount, StringFormat='{}{0:C}'}"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Service"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding Invoice.ServiceAmount, StringFormat='{}{0:C}'}"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Total"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding Invoice.TotalAmount, StringFormat='{}{0:C}'}"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="Remaining"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding Invoice.RemainingAmount, StringFormat='{}{0:C}'}"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource DangerBrush}" />
                        </StackPanel>
                    </UniformGrid>
                </materialDesign:Card>

                <materialDesign:Card Padding="16"
                                     Margin="0,0,0,12"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Rooms"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Invoice.RoomLines}"
                                  Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="Auto" MinWidth="70" />
                                <DataGridTextColumn Header="Type" Binding="{Binding RoomType}" Width="*" />
                                <DataGridTextColumn Header="Check-in" Binding="{Binding CheckInDate, StringFormat='yyyy-MM-dd'}" Width="Auto" MinWidth="96" />
                                <DataGridTextColumn Header="Check-out" Binding="{Binding CheckOutDate, StringFormat='yyyy-MM-dd'}" Width="Auto" MinWidth="96" />
                                <DataGridTextColumn Header="Nights" Binding="{Binding NumberOfNights}" Width="Auto" MinWidth="64" />
                                <DataGridTextColumn Header="Price" Binding="{Binding RoomPrice, StringFormat='{}{0:C}'}" Width="*" />
                                <DataGridTextColumn Header="Total" Binding="{Binding RoomTotal, StringFormat='{}{0:C}'}" Width="*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Padding="16"
                                     materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Services"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Invoice.ServiceLines}"
                                  Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="Auto" MinWidth="70" />
                                <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="1.4*" />
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="Auto" MinWidth="56" />
                                <DataGridTextColumn Header="Unit" Binding="{Binding UnitPrice, StringFormat='{}{0:C}'}" Width="*" />
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='{}{0:C}'}" Width="*" />
                                <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat='yyyy-MM-dd HH:mm'}" Width="Auto" MinWidth="124" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>

        <materialDesign:Card Padding="24"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Center"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <materialDesign:Card.Style>
                <Style TargetType="materialDesign:Card">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Invoice}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Card.Style>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="ReceiptText"
                                         Width="24"
                                         Height="24"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         Margin="0,0,8,0" />
                <TextBlock Text="{Binding EmptyMessage}"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
