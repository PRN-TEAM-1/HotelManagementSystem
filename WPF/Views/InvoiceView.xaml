<UserControl x:Class="WPF.Views.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#FFF3D6"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource WarningBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#DFF3E7"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="CheckCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource SuccessBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SuccessMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource SuccessBrush}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="420" />
                <ColumnDefinition Width="1.1*" MinWidth="480" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Row="0"
                                     Padding="16"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Checked-out Bookings"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <Button Grid.Column="1"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Refresh billing data">
                                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                            </Button>
                        </Grid>

                        <DockPanel Grid.Row="1" Margin="0,8,0,0" LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Command="{Binding SearchCandidatesCommand}"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Search">
                                    <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" />
                                </Button>
                                <Button Command="{Binding ClearCandidateSearchCommand}"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Clear search">
                                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20" />
                                </Button>
                            </StackPanel>

                            <TextBox Text="{Binding CandidateSearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanEdit}"
                                     materialDesign:HintAssist.Hint="Search bookings"
                                     materialDesign:TextFieldAssist.HasClearButton="True" />
                        </DockPanel>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <DataGrid ItemsSource="{Binding InvoiceCandidates}"
                                      SelectedItem="{Binding SelectedCandidate}"
                                      IsEnabled="{Binding CanEdit}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Booking" Binding="{Binding BookingId}" Width="Auto" MinWidth="72" />
                                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="1.5*" />
                                    <DataGridTextColumn Header="Rooms" Binding="{Binding RoomCount}" Width="Auto" MinWidth="64" />
                                    <DataGridTextColumn Header="Room" Binding="{Binding RoomAmount, StringFormat='{}{0:C}'}" Width="*" />
                                    <DataGridTextColumn Header="Service" Binding="{Binding ServiceAmount, StringFormat='{}{0:C}'}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Padding="16"
                                    Background="{StaticResource SurfaceMutedBrush}"
                                    CornerRadius="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding CandidateEmptyMessage, Converter={StaticResource StringToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileSearchOutline"
                                                             Width="22"
                                                             Height="22"
                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                             Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding CandidateEmptyMessage}"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3"
                              Margin="0,12,0,0"
                              Visibility="{Binding SelectedCandidate, Converter={StaticResource ObjectToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox Text="{Binding DiscountAmountText, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanEdit}"
                                     materialDesign:HintAssist.Hint="Discount" />

                            <TextBox Grid.Column="2"
                                     Text="{Binding TaxAmountText, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanEdit}"
                                     materialDesign:HintAssist.Hint="Tax" />

                            <TextBox Grid.Row="1"
                                     Grid.ColumnSpan="3"
                                     Text="{Binding InvoiceNote, UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="48"
                                     MaxHeight="80"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     IsEnabled="{Binding CanEdit}"
                                     materialDesign:HintAssist.Hint="Note" />

                        </Grid>

                        <Grid Grid.Row="4"
                              Margin="0,12,0,0"
                              Visibility="{Binding SelectedCandidate, Converter={StaticResource ObjectToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Total"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding PreviewTotalAmount, StringFormat='{}{0:C}'}"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Command="{Binding CreateInvoiceCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileDocumentPlus"
                                                             Width="18"
                                                             Height="18"
                                                             Margin="0,0,8,0" />
                                    <TextBlock Text="Create" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="2"
                                     Padding="16"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Invoices"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <DockPanel Grid.Row="1" Margin="0,8,0,0" LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Command="{Binding SearchInvoicesCommand}"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Search">
                                    <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" />
                                </Button>
                                <Button Command="{Binding ClearInvoiceSearchCommand}"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Clear search">
                                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20" />
                                </Button>
                            </StackPanel>

                            <TextBox Text="{Binding InvoiceSearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanEdit}"
                                     materialDesign:HintAssist.Hint="Search invoices"
                                     materialDesign:TextFieldAssist.HasClearButton="True" />
                        </DockPanel>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <DataGrid ItemsSource="{Binding Invoices}"
                                      SelectedItem="{Binding SelectedInvoice}"
                                      IsEnabled="{Binding CanEdit}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceId}" Width="Auto" MinWidth="72" />
                                    <DataGridTextColumn Header="Booking" Binding="{Binding BookingId}" Width="Auto" MinWidth="76" />
                                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="1.6*" />
                                    <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat='{}{0:C}'}" Width="*" />
                                    <DataGridTextColumn Header="Remain" Binding="{Binding RemainingAmount, StringFormat='{}{0:C}'}" Width="*" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="92" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Padding="16"
                                    Background="{StaticResource SurfaceMutedBrush}"
                                    CornerRadius="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding InvoiceEmptyMessage, Converter={StaticResource StringToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ReceiptText"
                                                             Width="22"
                                                             Height="22"
                                                             Foreground="{StaticResource TextSecondaryBrush}"
                                                             Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding InvoiceEmptyMessage}"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Button Grid.Row="3"
                                Command="{Binding ViewInvoiceDetailCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Eye"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Detail" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.1*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0.9*" />
                </Grid.RowDefinitions>

                <ContentControl Grid.Row="0"
                                Content="{Binding InvoiceDetail}" />

                <ContentControl Grid.Row="1"
                                Margin="0,12,0,0"
                                Content="{Binding PaymentView}" />

                <ContentControl Grid.Row="2"
                                Margin="0,12,0,0"
                                Content="{Binding PaymentHistory}" />
            </Grid>

            <Border Grid.ColumnSpan="2"
                    Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Width="180"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}" />
                    <TextBlock Text="Processing..."
                               Foreground="White"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               TextAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
