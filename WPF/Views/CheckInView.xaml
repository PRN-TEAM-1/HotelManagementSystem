<UserControl x:Class="WPF.Views.CheckInView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource WindowBackgroundBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Check-In Management"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="Check-in guests and update room status"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Messages Section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <!-- Error Message -->
            <Border Background="#FFE5C8"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="×"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#856404"
                            FontSize="16" />
                </Grid>
            </Border>

            <!-- Success Message -->
            <Border Background="#D4EDDA"
                    BorderBrush="#28A745"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="#155724"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="×"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#155724"
                            FontSize="16" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button Command="{Binding LoadCheckInCandidatesCommand}"
                    IsEnabled="{Binding CanEdit}"
                    Content="Refresh List"
                    Padding="12,8"
                    Background="{DynamicResource ButtonPrimaryBrush}"
                    Foreground="{DynamicResource TextInverseBrush}"
                    FontSize="13"
                    FontWeight="SemiBold" />
        </StackPanel>

        <!-- Candidates List -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding CheckInCandidates}"
                  SelectedItem="{Binding SelectedCandidate}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  IsEnabled="{Binding CanEdit}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Room #" Binding="{Binding RoomNumber}" Width="80" />
                <DataGridTextColumn Header="Floor" Binding="{Binding Floor}" Width="70" />
                <DataGridTextColumn Header="Type" Binding="{Binding RoomType}" Width="100" />
                <DataGridTextColumn Header="Check-In Date" Binding="{Binding CheckInDate, StringFormat='yyyy-MM-dd'}" Width="120" />
                <DataGridTextColumn Header="Check-Out Date" Binding="{Binding CheckOutDate, StringFormat='yyyy-MM-dd'}" Width="120" />
                <DataGridTextColumn Header="Nights" Binding="{Binding NumberOfNights}" Width="70" />
                <DataGridTextColumn Header="Price/Night" Binding="{Binding RoomPrice, StringFormat='C'}" Width="100" />
                <DataGridTextColumn Header="Status" Binding="{Binding BookingDetailStatus}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Check-In Form -->
        <Border Grid.Row="4"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="16"
                Margin="0,16,0,0"
                Visibility="{Binding SelectedCandidate, Converter={StaticResource ObjectToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Check-In Details"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Guest Name:"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding GuestName}"
                             IsEnabled="{Binding CanEdit}"
                             Padding="8,6"
                             Margin="8,0,0,0" />

                    <TextBlock Grid.Column="2"
                               Text="Guest Email:"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="3"
                             Text="{Binding GuestEmail}"
                             IsEnabled="{Binding CanEdit}"
                             Padding="8,6"
                             Margin="8,0,0,0" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Phone:"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Text="{Binding GuestPhone}"
                             IsEnabled="{Binding CanEdit}"
                             Padding="8,6"
                             Margin="8,0,0,0" />

                    <TextBlock Grid.Column="2"
                               Text="ID Number:"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="3"
                             Text="{Binding GuestIdNumber}"
                             IsEnabled="{Binding CanEdit}"
                             Padding="8,6"
                             Margin="8,0,0,0" />
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding CheckInCommand}"
                            IsEnabled="{Binding CanEdit}"
                            Content="Check In"
                            Padding="16,8"
                            Background="{DynamicResource ButtonPrimaryBrush}"
                            Foreground="{DynamicResource TextInverseBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Margin="0,0,8,0" />
                    <Button Command="{Binding CancelCommand}"
                            Content="Cancel"
                            Padding="16,8"
                            Background="Transparent"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource TextPrimaryBrush}"
                            BorderThickness="1"
                            FontSize="13"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
