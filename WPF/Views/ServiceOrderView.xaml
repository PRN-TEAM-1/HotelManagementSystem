<UserControl x:Class="WPF.Views.ServiceOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#FFF3D6"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource WarningBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#DFF3E7"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="CheckCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource SuccessBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SuccessMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource SuccessBrush}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Command="{Binding LoadServicesCommand}"
                                    IsEnabled="{Binding CanEdit}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Refresh services">
                                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                            </Button>
                            <Button Command="{Binding LoadServiceOrdersCommand}"
                                    IsEnabled="{Binding CanEdit}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Refresh orders">
                                <materialDesign:PackIcon Kind="ReceiptText" Width="20" Height="20" />
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ReceiptText"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Service Orders"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Padding="12"
                            Margin="0,12,0,0"
                            Background="{StaticResource SurfaceMutedBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Booking Detail"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding BookingDetailId}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Total"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding ServiceOrderTotal, StringFormat='{}{0:N0} VND'}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <DataGrid ItemsSource="{Binding ServiceOrders}"
                                  SelectedItem="{Binding SelectedServiceOrder}"
                                  IsEnabled="{Binding CanEdit}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  FrozenColumnCount="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="1.5*" MinWidth="150" />
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="Auto" MinWidth="64" />
                                <DataGridTextColumn Header="Unit" Binding="{Binding UnitPrice, StringFormat='{}{0:N0} VND'}" Width="*" MinWidth="90" />
                                <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='{}{0:N0} VND'}" Width="*" MinWidth="90" />
                                <DataGridTextColumn Header="Ordered" Binding="{Binding OrderDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="1.2*" MinWidth="120" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="92" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Chưa có dịch vụ nào khác, thêm mới ở bên phải"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ServiceOrders.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2"
                                 Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CashPlus"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Add Service"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <ComboBox ItemsSource="{Binding ActiveStays}"
                                  SelectedItem="{Binding SelectedStay}"
                                  IsEnabled="{Binding CanEdit}"
                                  Margin="0,0,0,16"
                                  materialDesign:HintAssist.Hint="Select Room / Stay">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="Room " FontWeight="SemiBold"/>
                                        <Run Text="{Binding RoomNumber}" FontWeight="SemiBold"/>
                                        <Run Text=" (Booking #"/>
                                        <Run Text="{Binding BookingId}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <ComboBox ItemsSource="{Binding AvailableServices}"
                                  SelectedItem="{Binding SelectedService}"
                                  DisplayMemberPath="ServiceName"
                                  IsEnabled="{Binding CanEdit}"
                                  Margin="0,0,0,4"
                                  materialDesign:HintAssist.Hint="Service" />
                                  
                        <TextBlock Text="{Binding SelectedService.Price, StringFormat='{}Giá: {0:N0} VND'}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="4,0,0,16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedService}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBox Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}"
                                 TextAlignment="Left"
                                 Margin="0,0,0,24"
                                 materialDesign:HintAssist.Hint="Quantity" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button Command="{Binding CreateServiceOrderCommand}"
                                IsEnabled="{Binding CanEdit}"
                                ToolTipService.ShowOnDisabled="True">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="ToolTip" Value="Add service order" />
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="ToolTip" Value="Vui lòng chọn Phòng, Dịch vụ và nhập Số lượng" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CashPlus" Width="18" Height="18" Margin="0,0,8,0" />
                                <TextBlock Text="Add" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CancelServiceOrderCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,0,0"
                                ToolTip="Cancel selected service order">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Margin="0,0,8,0" />
                                <TextBlock Text="Cancel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <Border Grid.ColumnSpan="3"
                    Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="160"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}" />
                    <TextBlock Text="Loading..."
                               Margin="0,8,0,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
