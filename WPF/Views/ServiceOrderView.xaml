<UserControl x:Class="WPF.Views.ServiceOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource WindowBackgroundBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Service Orders"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Record and manage service orders during guest stay"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Messages Section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <!-- Error Message -->
            <Border Background="#FFE5C8"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="×"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#856404"
                            FontSize="16" />
                </Grid>
            </Border>

            <!-- Success Message -->
            <Border Background="#D4EDDA"
                    BorderBrush="#28A745"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="#155724"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="×"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#155724"
                            FontSize="16" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Action Button -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button Command="{Binding LoadServiceOrdersCommand}"
                    IsEnabled="{Binding CanEdit}"
                    Content="Refresh"
                    Padding="12,8"
                    Background="{StaticResource ButtonPrimaryBrush}"
                    Foreground="{StaticResource TextInverseBrush}"
                    FontSize="13"
                    FontWeight="SemiBold" />
        </StackPanel>

        <!-- Service Orders List -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding ServiceOrders}"
                  SelectedItem="{Binding SelectedServiceOrder}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  IsEnabled="{Binding CanEdit}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Service Name" Binding="{Binding ServiceName}" Width="200" />
                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="80" />
                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat='C'}" Width="100" />
                <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat='C'}" Width="120" />
                <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate, StringFormat='yyyy-MM-dd HH:mm'}" Width="160" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Form Section -->
        <Border Grid.Row="4"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="16"
                Margin="0,16,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Summary"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding ServiceOrderTotal, StringFormat='Total Service Orders: {0:C}'}"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="Add New Service"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding AvailableServices}"
                              SelectedItem="{Binding SelectedService}"
                              DisplayMemberPath="ServiceName"
                              Background="White"
                              BorderBrush="#D0D0D0"
                              BorderThickness="1"
                              Padding="8"
                              FontSize="12"
                              IsEnabled="{Binding CanEdit}" />

                    <TextBlock Grid.Column="1"
                               Text="Quantity:"
                               VerticalAlignment="Center"
                               Margin="12,0,8,0" />
                    <TextBox Grid.Column="2"
                             Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                             Background="White"
                             BorderBrush="#D0D0D0"
                             BorderThickness="1"
                             Padding="8"
                             FontSize="12"
                             TextAlignment="Center"
                             IsEnabled="{Binding CanEdit}" />

                    <Button Grid.Column="3"
                            Command="{Binding CreateServiceOrderCommand}"
                            IsEnabled="{Binding CanEdit}"
                            Content="Add Service"
                            Padding="12,8"
                            Background="{StaticResource ButtonSuccessBrush}"
                            Foreground="{StaticResource TextInverseBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Margin="12,0,0,0" />
                </Grid>

                <Button Grid.Row="3"
                        Command="{Binding CancelServiceOrderCommand}"
                        IsEnabled="{Binding CanEdit}"
                        Content="Remove Selected Service"
                        Padding="12,8"
                        Background="#FF6B6B"
                        Foreground="{StaticResource TextInverseBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Left" />
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="3"
                Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="200" Height="4" IsIndeterminate="True" Background="#40FFFFFF" Foreground="#2196F3" />
                <TextBlock Text="Processing..." Foreground="White" FontSize="14" TextAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
