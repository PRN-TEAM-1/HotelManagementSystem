<UserControl x:Class="WPF.Views.ServiceOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#FFF3D6"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource WarningBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#DFF3E7"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="CheckCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource SuccessBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SuccessMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource SuccessBrush}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" MinWidth="480" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.75*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Command="{Binding LoadServicesCommand}"
                                    IsEnabled="{Binding CanEdit}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Refresh services">
                                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                            </Button>
                            <Button Command="{Binding LoadServiceOrdersCommand}"
                                    IsEnabled="{Binding CanEdit}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Refresh orders">
                                <materialDesign:PackIcon Kind="ReceiptText" Width="20" Height="20" />
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ReceiptText"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Service Orders"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Padding="12"
                            Margin="0,12,0,0"
                            Background="{StaticResource SurfaceMutedBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Booking Detail"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding BookingDetailId}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Total"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding ServiceOrderTotal, StringFormat='{}{0:C}'}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding ServiceOrders}"
                              SelectedItem="{Binding SelectedServiceOrder}"
                              IsEnabled="{Binding CanEdit}"
                              Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="1.5*" />
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="Auto" MinWidth="64" />
                            <DataGridTextColumn Header="Unit" Binding="{Binding UnitPrice, StringFormat='{}{0:C}'}" Width="*" />
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat='{}{0:C}'}" Width="*" />
                            <DataGridTextColumn Header="Ordered" Binding="{Binding OrderDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="1.2*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="92" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2"
                                 Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CashPlus"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Add Service"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBox Text="{Binding BookingDetailId, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}"
                                 materialDesign:HintAssist.Hint="Booking detail ID" />
                        <ComboBox ItemsSource="{Binding AvailableServices}"
                                  SelectedItem="{Binding SelectedService}"
                                  DisplayMemberPath="ServiceName"
                                  IsEnabled="{Binding CanEdit}"
                                  materialDesign:HintAssist.Hint="Service" />
                        <TextBox Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}"
                                 TextAlignment="Right"
                                 materialDesign:HintAssist.Hint="Quantity" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="12"
                            Margin="0,12,0,0"
                            Background="{StaticResource SurfaceMutedBrush}"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Selected Service"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedService.ServiceName, TargetNullValue=Select a service}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding SelectedService.Price, StringFormat='{}{0:C}', TargetNullValue=0}"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button Command="{Binding CreateServiceOrderCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Add service order">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CashPlus"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Add" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CancelServiceOrderCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0"
                                ToolTip="Cancel selected service order">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Close"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Cancel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <Border Grid.ColumnSpan="3"
                    Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="160"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}" />
                    <TextBlock Text="Loading..."
                               Margin="0,8,0,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
