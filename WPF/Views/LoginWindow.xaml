<Window x:Class="WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotel Management System - Sign In"
        Width="1080"
        Height="720"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="0.9*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="28">
            <Border Background="{StaticResource HeroBrush}" CornerRadius="32" Padding="36">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Hotel Management System"
                                   FontFamily="{StaticResource AppDisplayFont}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextInverseBrush}" />
                        <TextBlock Text="M1-AUTH-001 is now wired to EF Core, SQL Server and role-based navigation."
                                   Margin="0,12,0,0"
                                   FontSize="14"
                                   Foreground="#E3F1F7"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,32,0,0">
                        <Border Padding="22" Background="#1AFFFFFF" CornerRadius="22" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Auth rules enforced"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextInverseBrush}" />
                                <TextBlock Text="Only authenticated users can enter the main shell. Inactive and locked accounts are blocked before navigation opens."
                                           Margin="0,10,0,0"
                                           Foreground="#E3F1F7"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Padding="22" Background="#15000000" CornerRadius="22">
                            <StackPanel>
                                <TextBlock Text="Seed accounts"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextInverseBrush}" />
                                <TextBlock Text="Admin: admin / Admin@123"
                                           Margin="0,12,0,0"
                                           Foreground="#E3F1F7" />
                                <TextBlock Text="Manager: manager / Manager@123"
                                           Margin="0,8,0,0"
                                           Foreground="#E3F1F7" />
                                <TextBlock Text="Receptionist: reception / Reception@123"
                                           Margin="0,8,0,0"
                                           Foreground="#E3F1F7" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="16"
                            Background="#14000000"
                            CornerRadius="18">
                        <TextBlock Text="Connection string is loaded from WPF/appsettings.json through DbContextFactory, so the auth flow stays environment-configurable."
                                   Foreground="#E3F1F7"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Margin="0,28,28,28">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="32"
                    Padding="40"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Sign in"
                               FontFamily="{StaticResource AppDisplayFont}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Use your internal hotel staff account to continue."
                               Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Username"
                               Margin="0,28,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEdit}" />

                    <TextBlock Text="Password"
                               Margin="0,20,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <PasswordBox PasswordChanged="OnPasswordChanged"
                                 IsEnabled="{Binding CanEdit}" />

                    <TextBlock Text="{Binding ErrorMessage}"
                               Margin="0,14,0,0"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               MinHeight="36" />

                    <Button Command="{Binding LoginCommand}"
                            IsDefault="True"
                            Margin="0,14,0,0"
                            HorizontalAlignment="Stretch"
                            MinWidth="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Content" Value="Sign in" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Content" Value="Signing in..." />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
