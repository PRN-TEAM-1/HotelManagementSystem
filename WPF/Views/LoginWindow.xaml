<Window x:Class="WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Hotel Management System - Sign In"
        Width="1080"
        Height="680"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <materialDesign:Card Grid.Column="0"
                             Padding="32"
                             Margin="0,0,16,0"
                             Background="{StaticResource HeroBrush}"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Hotel Management"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                               FontFamily="{StaticResource AppDisplayFont}"
                               Foreground="{StaticResource TextInverseBrush}" />
                    <TextBlock Text="Internal operations"
                               Margin="0,8,0,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="#DDECF3" />
                </StackPanel>

                <Grid Grid.Row="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="72"
                            Height="72"
                            CornerRadius="16"
                            Background="#22FFFFFF"
                            VerticalAlignment="Top">
                        <materialDesign:PackIcon Kind="OfficeBuilding"
                                                 Width="36"
                                                 Height="36"
                                                 Foreground="{StaticResource TextInverseBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="Front desk, billing and reports in one workspace."
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Foreground="{StaticResource TextInverseBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Sign in with your staff account to continue."
                                   Margin="0,8,0,0"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Foreground="#DDECF3"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Hotel staff system"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Foreground="#C4DAE5" />
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1"
                             Padding="28"
                             VerticalAlignment="Center"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel>
                <TextBlock Text="Sign In"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           FontFamily="{StaticResource AppDisplayFont}"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEdit}"
                         Margin="0,28,0,8"
                         materialDesign:HintAssist.Hint="Username"
                         materialDesign:TextFieldAssist.HasClearButton="True" />

                <PasswordBox PasswordChanged="OnPasswordChanged"
                             IsEnabled="{Binding CanEdit}"
                             Margin="0,8,0,8"
                             materialDesign:HintAssist.Hint="Password" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Margin="0,8,0,0"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap"
                           MinHeight="28" />

                <Button Command="{Binding LoginCommand}"
                        IsDefault="True"
                        HorizontalAlignment="Stretch"
                        MinWidth="0"
                        Margin="0,16,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Login"
                                                                 Width="18"
                                                                 Height="18"
                                                                 Margin="0,0,8,0" />
                                        <TextBlock Text="Sign in" />
                                    </StackPanel>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Content" Value="Signing in..." />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
