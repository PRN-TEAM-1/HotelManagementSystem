<UserControl x:Class="WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPF.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12" LastChildFill="True">
            <Button DockPanel.Dock="Right"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTip="Refresh dashboard">
                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
            </Button>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ViewDashboard"
                                         Width="20"
                                         Height="20"
                                         Foreground="{StaticResource AccentBrush}"
                                         Margin="0,0,8,0" />
                <TextBlock Text="Today"
                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <materialDesign:Card Padding="16"
                                     Margin="0,0,0,12"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="OfficeBuilding"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Room Summary"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
                                     Columns="3"
                                     Margin="0,12,0,0">
                            <controls:DashboardCardControl Title="Total Rooms"
                                                           Value="{Binding Dashboard.RoomSummary.TotalRooms}" />
                            <controls:DashboardCardControl Title="Available"
                                                           Value="{Binding Dashboard.RoomSummary.AvailableRooms}" />
                            <controls:DashboardCardControl Title="Occupied"
                                                           Value="{Binding Dashboard.RoomSummary.OccupiedRooms}" />
                            <controls:DashboardCardControl Title="Reserved"
                                                           Value="{Binding Dashboard.RoomSummary.ReservedRooms}" />
                            <controls:DashboardCardControl Title="Cleaning"
                                                           Value="{Binding Dashboard.RoomSummary.CleaningRooms}" />
                            <controls:DashboardCardControl Title="Maintenance"
                                                           Value="{Binding Dashboard.RoomSummary.MaintenanceRooms}" />
                        </UniformGrid>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Padding="16"
                                     materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ReceiptText"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Operations"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
                                     Columns="3"
                                     Margin="0,12,0,0">
                            <controls:DashboardCardControl Title="Bookings"
                                                           Value="{Binding Dashboard.BookingSummary.TodayBookings}" />
                            <controls:DashboardCardControl Title="Check-ins"
                                                           Value="{Binding Dashboard.TodayOperation.TodayCheckIns}" />
                            <controls:DashboardCardControl Title="Check-outs"
                                                           Value="{Binding Dashboard.TodayOperation.TodayCheckOuts}" />
                        </UniformGrid>
                    </Grid>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
