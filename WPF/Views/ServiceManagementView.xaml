<UserControl x:Class="WPF.Views.ServiceManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource WindowBackgroundBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Service Management"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Manage service catalog and pricing"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Messages Section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <!-- Error Message -->
            <Border Background="#FFE5C8"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="×"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#856404"
                            FontSize="16" />
                </Grid>
            </Border>

            <!-- Success Message -->
            <Border Background="#D4EDDA"
                    BorderBrush="#28A745"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="#155724"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="×"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#155724"
                            FontSize="16" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Search and Action Buttons -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                <TextBox Background="White"
                         BorderBrush="#D0D0D0"
                         BorderThickness="1"
                         Padding="10,8"
                         FontSize="12"
                         Width="300"
                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEdit}" />
                <Button Command="{Binding SearchServicesCommand}"
                        IsEnabled="{Binding CanEdit}"
                        Content="Search"
                        Padding="12,8"
                        Background="{StaticResource ButtonPrimaryBrush}"
                        Foreground="{StaticResource TextInverseBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Margin="8,0,0,0" />
                <Button Command="{Binding LoadServicesCommand}"
                        IsEnabled="{Binding CanEdit}"
                        Content="Reset"
                        Padding="12,8"
                        Background="{StaticResource ButtonSecondaryBrush}"
                        Foreground="{StaticResource TextBrush}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Margin="8,0,0,0" />
            </StackPanel>

            <Button Grid.Column="2"
                    Command="{Binding CreateServiceCommand}"
                    IsEnabled="{Binding CanEdit}"
                    Content="Add Service"
                    Padding="12,8"
                    Background="{StaticResource ButtonSuccessBrush}"
                    Foreground="{StaticResource TextInverseBrush}"
                    FontSize="13"
                    FontWeight="SemiBold" />
        </Grid>

        <!-- Services List -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Services}"
                  SelectedItem="{Binding SelectedService}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  IsEnabled="{Binding CanEdit}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Service Name" Binding="{Binding ServiceName}" Width="200" />
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150" />
                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='C'}" Width="100" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Service Form -->
        <Border Grid.Row="4"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="16"
                Margin="0,16,0,0"
                Visibility="{Binding SelectedService, Converter={StaticResource ObjectToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Service Details"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Service Name:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged}"
                             Background="White"
                             BorderBrush="#D0D0D0"
                             BorderThickness="1"
                             Padding="8"
                             FontSize="12"
                             IsEnabled="{Binding CanEdit}" />

                    <TextBlock Grid.Column="2"
                               Text="Category:"
                               VerticalAlignment="Center"
                               Margin="16,0,8,0" />
                    <TextBox Grid.Column="3"
                             Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                             Background="White"
                             BorderBrush="#D0D0D0"
                             BorderThickness="1"
                             Padding="8"
                             FontSize="12"
                             IsEnabled="{Binding CanEdit}" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Price:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="1"
                             Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"
                             Background="White"
                             BorderBrush="#D0D0D0"
                             BorderThickness="1"
                             Padding="8"
                             FontSize="12"
                             IsEnabled="{Binding CanEdit}" />
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Status: " VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding SelectedServiceDetails.Status}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding UpdateServiceCommand}"
                            IsEnabled="{Binding CanEdit}"
                            Content="Save Changes"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"
                            Padding="16,10"
                            Background="{StaticResource ButtonPrimaryBrush}"
                            Foreground="{StaticResource TextInverseBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Margin="0,0,8,0" />
                    <Button Command="{Binding InactivateServiceCommand}"
                            IsEnabled="{Binding CanEdit}"
                            Content="Inactivate"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"
                            Padding="16,10"
                            Background="#FF6B6B"
                            Foreground="{StaticResource TextInverseBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Margin="0,0,8,0" />
                    <Button Click="OnCancelClick"
                            IsEnabled="{Binding CanEdit}"
                            Content="Cancel"
                            Padding="16,10"
                            Background="{StaticResource ButtonSecondaryBrush}"
                            Foreground="{StaticResource TextBrush}"
                            FontSize="13"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="3"
                Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="200" Height="4" IsIndeterminate="True" Background="#40FFFFFF" Foreground="#2196F3" />
                <TextBlock Text="Processing..." Foreground="White" FontSize="14" TextAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
