<UserControl x:Class="WPF.Views.ServiceManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#FFF3D6"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource WarningBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#DFF3E7"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="CheckCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource SuccessBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SuccessMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource SuccessBrush}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Service"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,16,0,0">
                        <TextBox Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}"
                                 materialDesign:HintAssist.Hint="Service name" />
                        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}"
                                 materialDesign:HintAssist.Hint="Category" />
                        <TextBox Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}"
                                 materialDesign:HintAssist.Hint="Price" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="12"
                            Margin="0,12,0,0"
                            Background="{StaticResource SurfaceMutedBrush}"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Status"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedServiceDetails.Status, TargetNullValue=New service}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button Command="{Binding CreateServiceCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Visibility="{Binding IsCreateMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="Create service">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocumentPlus"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Create" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding UpdateServiceCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="Save service">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Save" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding InactivateServiceCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="Inactivate service">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountOff"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Inactive" />
                            </StackPanel>
                        </Button>
                        <Button Click="OnCancelClick"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0"
                                ToolTip="Clear form">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Close"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2"
                                 Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ReceiptText"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Service Catalog"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <DockPanel Grid.Row="1" Margin="0,12,0,0" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button Command="{Binding SearchServicesCommand}"
                                    IsEnabled="{Binding CanEdit}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Search">
                                <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" />
                            </Button>
                            <Button Command="{Binding LoadServicesCommand}"
                                    IsEnabled="{Binding CanEdit}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Refresh">
                                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                            </Button>
                        </StackPanel>

                        <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}"
                                 materialDesign:HintAssist.Hint="Search services"
                                 materialDesign:TextFieldAssist.HasClearButton="True" />
                    </DockPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Services}"
                              SelectedItem="{Binding SelectedService}"
                              IsEnabled="{Binding CanEdit}"
                              Margin="0,8,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="1.6*" />
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat='{}{0:C}'}" Width="*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="96" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <Border Grid.ColumnSpan="3"
                    Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="160"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}" />
                    <TextBlock Text="Loading..."
                               Margin="0,8,0,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
