<UserControl x:Class="WPF.Views.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Visibility="{Binding HasInvoice, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Record Payment"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding InvoiceLabel}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="Remaining"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="{Binding RemainingAmount, StringFormat='{}{0:C}'}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DangerBrush}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Background="#FFE5C8"
                        BorderBrush="#FFC107"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,10,0,0"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#856404"
                                   TextWrapping="Wrap" />
                        <Button Grid.Column="1"
                                Command="{Binding ClearMessagesCommand}"
                                Content="x"
                                Width="24"
                                Height="24"
                                MinWidth="24"
                                Padding="0"
                                Margin="8,0,0,0"
                                Background="Transparent"
                                Foreground="#856404"
                                BorderThickness="0" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,10,0,0"
                        Visibility="{Binding PaymentStateMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding PaymentStateMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Amount"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Method"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <ComboBox ItemsSource="{Binding PaymentMethods}"
                                  SelectedItem="{Binding SelectedPaymentMethod}"
                                  IsEnabled="{Binding CanEdit}" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Use Remaining"
                            Command="{Binding UseRemainingAmountCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="10,0,0,0" />

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,10,0,0">
                        <TextBlock Text="Transaction code"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBox Text="{Binding TransactionCode, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEdit}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0">
                        <TextBlock Text="Note"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                 Height="54"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 IsEnabled="{Binding CanEdit}" />

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,12,0,0">
                            <Button Content="Reset"
                                    Command="{Binding ResetFormCommand}"
                                    Style="{StaticResource GhostButtonStyle}" />
                            <Button Content="Record Payment"
                                    Command="{Binding RecordPaymentCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasInvoice}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="Select an invoice detail to record a payment."
                       TextAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
