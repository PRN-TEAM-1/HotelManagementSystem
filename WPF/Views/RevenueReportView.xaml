<UserControl x:Class="WPF.Views.RevenueReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:Card Padding="16"
                             Margin="0,0,0,12"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <DatePicker SelectedDate="{Binding StartDate}"
                            materialDesign:HintAssist.Hint="Start date" />
                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding EndDate}"
                            Margin="8,0,0,8"
                            materialDesign:HintAssist.Hint="End date" />

                <Button Grid.Column="2"
                        Command="{Binding FilterCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        ToolTip="Filter report">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Filter" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Command="{Binding ExportCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        ToolTip="Export CSV">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentPlus"
                                                 Width="18"
                                                 Height="18"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Export" />
                    </StackPanel>
                </Button>

                <Border Grid.Column="4"
                        Padding="12"
                        Margin="12,0,0,0"
                        Background="{StaticResource SurfaceMutedBrush}"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Revenue"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding TotalRevenue, StringFormat='{}{0:N0} VND'}"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </materialDesign:Card>

        <Border Grid.Row="1"
                Padding="12"
                Margin="0,0,0,12"
                Background="#FFF3D6"
                CornerRadius="8"
                Visibility="{Binding Message, Converter={StaticResource StringToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                         Width="20"
                                         Height="20"
                                         Foreground="{StaticResource WarningBrush}"
                                         VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Message}"
                           Margin="8,0,0,0"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Foreground="#856404"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.75*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CashRegister"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Daily Revenue"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding RevenueReports}"
                              Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*" />
                            <DataGridTextColumn Header="Payments" Binding="{Binding PaymentCount}" Width="Auto" MinWidth="96" />
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalRevenue, StringFormat='{}{0:N0} VND'}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2"
                                 Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CreditCardOutline"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Payment Methods"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding PaymentMethodReports}"
                              Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Method" Binding="{Binding PaymentMethod}" Width="*" />
                            <DataGridTextColumn Header="Payments" Binding="{Binding PaymentCount}" Width="Auto" MinWidth="88" />
                            <DataGridTextColumn Header="Revenue" Binding="{Binding TotalRevenue, StringFormat='{}{0:N0} VND'}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
