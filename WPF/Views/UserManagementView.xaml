<UserControl x:Class="WPF.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#FFF3D6"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource WarningBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#DFF3E7"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="CheckCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource SuccessBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SuccessMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource SuccessBrush}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <materialDesign:Card Grid.Row="1"
                             Padding="16"
                             Margin="0,0,0,12"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                        <Button Command="{Binding SearchUsersCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Search">
                            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" />
                        </Button>
                        <Button Command="{Binding ClearSearchCommand}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Clear search">
                            <materialDesign:PackIcon Kind="Close" Width="20" Height="20" />
                        </Button>
                        <Button Command="{Binding LoadUsersCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Refresh">
                            <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                        </Button>
                    </StackPanel>

                    <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEdit}"
                             materialDesign:HintAssist.Hint="Search staff"
                             materialDesign:TextFieldAssist.HasClearButton="True" />
                </DockPanel>

                <WrapPanel Grid.Column="1"
                           Margin="16,0,0,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button Command="{Binding AddUserCommand}"
                            IsEnabled="{Binding CanEdit}"
                            Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountPlus"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Add" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditUserCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Edit account">
                        <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding ActivateUserCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Activate account">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding InactivateUserCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Set inactive">
                        <materialDesign:PackIcon Kind="AccountOff" Width="20" Height="20" />
                    </Button>
                    <Button Command="{Binding LockUserCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Lock account">
                        <materialDesign:PackIcon Kind="Lock" Width="20" Height="20" />
                    </Button>
                </WrapPanel>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2">
            <DataGrid ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      IsEnabled="{Binding CanEdit}"
                      HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="1*" />
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="1.4*" />
                    <DataGridTextColumn Header="Role" Binding="{Binding RoleName}" Width="Auto" MinWidth="96" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.6*" />
                    <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="Auto" MinWidth="108" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="92" />
                    <DataGridCheckBoxColumn Header="Activity" Binding="{Binding HasBusinessReferences}" Width="Auto" MinWidth="84" />
                    <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="Auto" MinWidth="132" />
                </DataGrid.Columns>
            </DataGrid>

            <materialDesign:Card Padding="16"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding EmptyStateMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AccountSearch"
                                             Width="22"
                                             Height="22"
                                             Foreground="{StaticResource TextSecondaryBrush}"
                                             Margin="0,0,8,0" />
                    <TextBlock Text="{Binding EmptyStateMessage}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </materialDesign:Card>

            <Border Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Width="180"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}" />
                    <TextBlock Text="Processing..."
                               Foreground="White"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               TextAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <materialDesign:Card Grid.Row="3"
                             Margin="0,12,0,0"
                             Padding="16"
                             materialDesign:ElevationAssist.Elevation="Dp1"
                             Visibility="{Binding SelectedUser, Converter={StaticResource ObjectToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Selected"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding SelectedUser.Username}"
                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Full name"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding SelectedUser.FullName}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="24,0,0,0">
                    <TextBlock Text="Role"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding SelectedUser.RoleName}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="24,0,0,0">
                    <TextBlock Text="Status"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding SelectedUser.Status}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource AccentBrush}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
