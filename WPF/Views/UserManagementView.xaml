<UserControl x:Class="WPF.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource WindowBackgroundBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="User Management"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock Text="Manage staff accounts, roles and login status"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Background="#FFE5C8"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="x"
                            Width="24"
                            Height="24"
                            MinWidth="24"
                            Padding="0"
                            Margin="8,0,0,0"
                            Background="Transparent"
                            Foreground="#856404"
                            BorderThickness="0" />
                </Grid>
            </Border>

            <Border Background="#D4EDDA"
                    BorderBrush="#28A745"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="#155724"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="x"
                            Width="24"
                            Height="24"
                            MinWidth="24"
                            Padding="0"
                            Margin="8,0,0,0"
                            Background="Transparent"
                            Foreground="#155724"
                            BorderThickness="0" />
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBox Width="280"
                         Margin="0,0,8,0"
                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEdit}" />
                <Button Content="Search"
                        Command="{Binding SearchUsersCommand}"
                        IsEnabled="{Binding CanEdit}"
                        MinWidth="88"
                        Padding="12,8"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="Clear"
                        Command="{Binding ClearSearchCommand}"
                        MinWidth="88"
                        Padding="12,8"
                        Style="{StaticResource GhostButtonStyle}" />
                <Button Content="Refresh"
                        Command="{Binding LoadUsersCommand}"
                        IsEnabled="{Binding CanEdit}"
                        MinWidth="88"
                        Padding="12,8"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Add User"
                        Command="{Binding AddUserCommand}"
                        IsEnabled="{Binding CanEdit}"
                        MinWidth="96"
                        Padding="12,8"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="Edit"
                        Command="{Binding EditUserCommand}"
                        MinWidth="76"
                        Padding="12,8"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="Activate"
                        Command="{Binding ActivateUserCommand}"
                        MinWidth="86"
                        Padding="12,8"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Content="Inactive"
                        Command="{Binding InactivateUserCommand}"
                        MinWidth="86"
                        Padding="12,8"
                        Style="{StaticResource GhostButtonStyle}" />
                <Button Content="Lock"
                        Command="{Binding LockUserCommand}"
                        MinWidth="76"
                        Padding="12,8"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="0" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3">
            <DataGrid ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      IsEnabled="{Binding CanEdit}"
                      HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="130" />
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="190" />
                    <DataGridTextColumn Header="Role" Binding="{Binding RoleName}" Width="120" />
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220" />
                    <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="120" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                    <DataGridCheckBoxColumn Header="Has Activity" Binding="{Binding HasBusinessReferences}" Width="110" />
                    <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Background="{StaticResource SurfaceMutedBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding EmptyStateMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <TextBlock Text="{Binding EmptyStateMessage}"
                           FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Border>

            <Border Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar Width="220"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Background="#40FFFFFF"
                                 Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Processing..."
                               Foreground="White"
                               FontSize="14"
                               TextAlignment="Center"
                               Margin="0,12,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Margin="0,16,0,0"
                Padding="16"
                Background="{StaticResource SurfaceMutedBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding SelectedUser, Converter={StaticResource ObjectToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Selected account"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding SelectedUser.Username}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Full name"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding SelectedUser.FullName}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Role"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding SelectedUser.RoleName}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Status"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding SelectedUser.Status}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
