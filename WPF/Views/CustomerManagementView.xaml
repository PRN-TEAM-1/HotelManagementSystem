<UserControl x:Class="WPF.Views.CustomerManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WPF.ViewModels">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="16" Background="#F7FAFC" CornerRadius="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Customer, Room, Room Map and Booking" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Create guests, inspect available rooms, and create a reservation from one place." Margin="0,6,0,0" Foreground="#5B6B7A" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="Customer + Booking">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Create Customer" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBox Text="{Binding IdentityCard, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                        <Button Content="Create Customer" Command="{Binding CreateCustomerCommand}" />

                        <TextBlock Text="Customers" FontWeight="SemiBold" Margin="0,16,0,8" />
                        <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                        <Button Content="Search" Command="{Binding SearchCustomersCommand}" Margin="0,0,0,8" />
                        <ListView ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" Height="220">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding FullName}" Width="140" />
                                    <GridViewColumn Header="Phone" DisplayMemberBinding="{Binding PhoneNumber}" Width="120" />
                                    <GridViewColumn Header="Identity" DisplayMemberBinding="{Binding IdentityCard}" Width="120" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Create Booking" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="Check-in" Margin="0,0,0,4" />
                        <DatePicker SelectedDate="{Binding CheckInDate}" Margin="0,0,0,8" />
                        <TextBlock Text="Check-out" Margin="0,0,0,4" />
                        <DatePicker SelectedDate="{Binding CheckOutDate}" Margin="0,0,0,8" />
                        <Button Content="Refresh Available Rooms" Command="{Binding RefreshRoomsCommand}" Margin="0,0,0,8" />
                        <ListView ItemsSource="{Binding AvailableRooms}" SelectedItem="{Binding SelectedRoom}" Height="180" Margin="0,0,0,8">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Room" DisplayMemberBinding="{Binding RoomNumber}" Width="80" />
                                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding RoomTypeName}" Width="120" />
                                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="100" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <Button Content="Create Booking" Command="{Binding CreateBookingCommand}" />
                        <TextBlock Text="{Binding Message}" Margin="0,10,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Room Map">
                <StackPanel Margin="8">
                    <TextBlock Text="Current room map" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="This screen is backed by the room inventory and booking date range from the service layer." Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding AvailableRooms}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="10" Background="#F8FAFB" CornerRadius="8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding RoomNumber}" FontWeight="SemiBold" Width="80" />
                                        <TextBlock Text="{Binding RoomTypeName}" Width="140" />
                                        <TextBlock Text="{Binding Status}" Width="120" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </TabItem>

            <TabItem Header="Bookings">
                <ListView ItemsSource="{Binding Bookings}" Margin="8">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Booking ID" DisplayMemberBinding="{Binding BookingId}" Width="90" />
                            <GridViewColumn Header="Customer" DisplayMemberBinding="{Binding CustomerName}" Width="140" />
                            <GridViewColumn Header="Rooms" DisplayMemberBinding="{Binding RoomNumbers}" Width="120" />
                            <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="100" />
                            <GridViewColumn Header="Total" DisplayMemberBinding="{Binding RoomTotal}" Width="100" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
