<UserControl x:Class="WPF.Views.CustomerManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="12"
                Margin="0,0,0,12"
                Background="{StaticResource SurfaceMutedBrush}"
                CornerRadius="8"
                Visibility="{Binding Message, Converter={StaticResource StringToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon Kind="InformationOutline"
                                         Width="20"
                                         Height="20"
                                         Foreground="{StaticResource AccentBrush}"
                                         VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Message}"
                           Margin="8,0,0,0"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <TabControl>
                <TabItem Header="Booking Desk">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" MinWidth="360" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1.1*" MinWidth="420" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <materialDesign:Card Padding="16"
                                                 materialDesign:ElevationAssist.Elevation="Dp2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountPlus"
                                                                 Width="20"
                                                                 Height="20"
                                                                 Foreground="{StaticResource AccentBrush}"
                                                                 Margin="0,0,8,0" />
                                        <TextBlock Text="Guest"
                                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>

                                    <Grid Grid.Row="1" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Full name" />
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding IdentityCard, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Identity card" />
                                        <TextBox Grid.Row="1"
                                                 Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Phone" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="2"
                                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Email" />
                                        <TextBox Grid.Row="2"
                                                 Grid.ColumnSpan="3"
                                                 Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Address" />
                                    </Grid>

                                    <Button Grid.Row="2"
                                            Command="{Binding CreateCustomerCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Margin="0,4,0,0"
                                            ToolTip="Create guest profile">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AccountPlus"
                                                                     Width="18"
                                                                     Height="18"
                                                                     Margin="0,0,8,0" />
                                            <TextBlock Text="Create" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </materialDesign:Card>

                            <materialDesign:Card Grid.Row="2"
                                                 Padding="16"
                                                 materialDesign:ElevationAssist.Elevation="Dp2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountSearch"
                                                                 Width="20"
                                                                 Height="20"
                                                                 Foreground="{StaticResource AccentBrush}"
                                                                 Margin="0,0,8,0" />
                                        <TextBlock Text="Customers"
                                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>

                                    <DockPanel Grid.Row="1" Margin="0,12,0,0" LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                Command="{Binding SearchCustomersCommand}"
                                                Style="{StaticResource IconButtonStyle}"
                                                Margin="8,0,0,0"
                                                ToolTip="Search customers">
                                            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" />
                                        </Button>
                                        <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Search customers"
                                                 materialDesign:TextFieldAssist.HasClearButton="True" />
                                    </DockPanel>

                                    <DataGrid Grid.Row="2"
                                              ItemsSource="{Binding Customers}"
                                              SelectedItem="{Binding SelectedCustomer}"
                                              Margin="0,8,0,0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="1.5*" />
                                            <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="*" />
                                            <DataGridTextColumn Header="Identity" Binding="{Binding IdentityCard}" Width="*" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>

                        <materialDesign:Card Grid.Column="2"
                                             Padding="16"
                                             materialDesign:ElevationAssist.Elevation="Dp2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileDocumentPlus"
                                                                 Width="20"
                                                                 Height="20"
                                                                 Foreground="{StaticResource AccentBrush}"
                                                                 Margin="0,0,8,0" />
                                        <TextBlock Text="Booking"
                                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding RefreshRoomsCommand}"
                                            Style="{StaticResource IconButtonStyle}"
                                            ToolTip="Refresh available rooms">
                                        <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <DatePicker SelectedDate="{Binding CheckInDate}"
                                                materialDesign:HintAssist.Hint="Check-in" />
                                    <DatePicker Grid.Column="2"
                                                SelectedDate="{Binding CheckOutDate}"
                                                materialDesign:HintAssist.Hint="Check-out" />
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,4,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="12"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Customer"
                                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding SelectedCustomer.FullName, TargetNullValue=Select a customer}"
                                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="12"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="Room"
                                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding SelectedRoom.RoomNumber, TargetNullValue=Select a room}"
                                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <ListBox Grid.Row="3"
                                         ItemsSource="{Binding AvailableRooms}"
                                         SelectedItem="{Binding SelectedRoom}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Margin" Value="0,0,8,8" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="152"
                                                    MinHeight="84"
                                                    Padding="12"
                                                    Background="{StaticResource SurfaceMutedBrush}"
                                                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="OfficeBuilding"
                                                                                 Width="18"
                                                                                 Height="18"
                                                                                 Foreground="{StaticResource AccentBrush}"
                                                                                 Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding RoomNumber}"
                                                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding RoomTypeName}"
                                                               Margin="0,6,0,0"
                                                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Status}"
                                                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                               Foreground="{StaticResource SuccessBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Grid.Row="4"
                                        Command="{Binding CreateBookingCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Right"
                                        Margin="0,12,0,0"
                                        ToolTip="Create booking from selected customer and room">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileDocumentPlus"
                                                                 Width="18"
                                                                 Height="18"
                                                                 Margin="0,0,8,0" />
                                        <TextBlock Text="Book" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>

                <TabItem Header="Room Map">
                    <materialDesign:Card Margin="0,12,0,0"
                                         Padding="16"
                                         materialDesign:ElevationAssist.Elevation="Dp2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding RefreshRoomsCommand}"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Refresh room map">
                                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                                </Button>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="OfficeBuilding"
                                                             Width="20"
                                                             Height="20"
                                                             Foreground="{StaticResource AccentBrush}"
                                                             Margin="0,0,8,0" />
                                    <TextBlock Text="Available Rooms"
                                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </DockPanel>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding AvailableRooms}"
                                     SelectedItem="{Binding SelectedRoom}"
                                     Margin="0,12,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="0,0,8,8" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="180"
                                                Padding="12"
                                                Background="{StaticResource SurfaceMutedBrush}"
                                                BorderBrush="{StaticResource SurfaceBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <materialDesign:PackIcon Kind="OfficeBuilding"
                                                                         Width="24"
                                                                         Height="24"
                                                                         Foreground="{StaticResource AccentBrush}"
                                                                         Margin="0,0,10,0" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding RoomNumber}"
                                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Grid.Row="1"
                                                           Grid.ColumnSpan="2"
                                                           Text="{Binding RoomTypeName}"
                                                           Margin="0,8,0,0"
                                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </materialDesign:Card>
                </TabItem>

                <TabItem Header="Recent Bookings">
                    <materialDesign:Card Margin="0,12,0,0"
                                         Padding="16"
                                         materialDesign:ElevationAssist.Elevation="Dp2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ReceiptText"
                                                         Width="20"
                                                         Height="20"
                                                         Foreground="{StaticResource AccentBrush}"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Recent Bookings"
                                           Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Bookings}"
                                      Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Booking" Binding="{Binding BookingId}" Width="Auto" MinWidth="76" />
                                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="1.4*" />
                                    <DataGridTextColumn Header="Rooms" Binding="{Binding RoomNumbers}" Width="*" />
                                    <DataGridTextColumn Header="Check-in" Binding="{Binding CheckInDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*" />
                                    <DataGridTextColumn Header="Check-out" Binding="{Binding CheckOutDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto" MinWidth="92" />
                                    <DataGridTextColumn Header="Total" Binding="{Binding RoomTotal, StringFormat='{}{0:N0} VND'}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </materialDesign:Card>
                </TabItem>
            </TabControl>

            <Border Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="160"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}" />
                    <TextBlock Text="Loading..."
                               Margin="0,8,0,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
