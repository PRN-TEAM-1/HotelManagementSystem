<Window x:Class="WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Hotel Management System"
        Width="1400"
        Height="860"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding AppTitle}"
                               FontFamily="{StaticResource AppDisplayFont}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextInverseBrush}" />
                    <TextBlock Text="{Binding AppSubtitle}"
                               Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="#C2D5E6"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,24,0,0"
                        Padding="18"
                        Background="#12314A"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="M1-AUTH-001 online"
                                   Foreground="{StaticResource TextInverseBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="This shell is now unlocked by real login, backed by EF Core and ready for the remaining vertical slices."
                                   Margin="0,8,0,0"
                                   Foreground="#C2D5E6"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2"
                              Margin="0,24,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Tag="{Binding IsSelected}"
                                        Style="{StaticResource NavigationButtonStyle}"
                                        Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TitleText}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Caption}"
                                                   Margin="0,5,0,0"
                                                   Foreground="#C2D5E6"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="3"
                        Margin="0,24,0,0"
                        Padding="18"
                        Background="#0B2235"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="{Binding AuthenticationState}"
                                   Foreground="{StaticResource TextInverseBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SessionDisplayName}"
                                   Margin="0,6,0,0"
                                   Foreground="#DCE8F3"
                                   FontSize="16"
                                   FontFamily="{StaticResource AppDisplayFont}" />
                        <TextBlock Text="{Binding SessionRoleDisplay}"
                                   Margin="0,4,0,0"
                                   Foreground="#A9C4D9"
                                   FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="24"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding CurrentPageTitle}"
                                   FontFamily="{StaticResource AppDisplayFont}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CurrentPageDescription}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="Back"
                                Command="{Binding GoBackCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Logout"
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Margin="0,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,24,0,0"
                    Padding="28"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Border>
        </Grid>
    </Grid>
</Window>
