<UserControl x:Class="WPF.Views.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <UserControl.Resources>
        <Style x:Key="SessionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Background="{StaticResource HeroBrush}" CornerRadius="24" Padding="28">
                <StackPanel>
                    <TextBlock Text="Authenticated Session"
                               FontFamily="{StaticResource AppDisplayFont}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextInverseBrush}" />
                    <TextBlock Text="This page reflects the real login state stored in CurrentUserService after authentication succeeds."
                               Margin="0,12,0,0"
                               Foreground="#E3F1F7"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SessionCardStyle}" Padding="24" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Profile Snapshot"
                                   FontFamily="{StaticResource AppDisplayFont}"
                                   FontSize="22"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <Grid Margin="0,18,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="State" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding SessionState}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1" Text="Display Name" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Grid.Row="2" Text="Username" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Text="{Binding Username}" Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Grid.Row="3" Text="Role" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Text="{Binding RoleDisplay}" Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Grid.Row="4" Text="Email" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Text="{Binding Email}" Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Grid.Row="5" Text="Signed In" Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,12,0,0" Text="{Binding LoggedInAtDisplay}" Foreground="{StaticResource TextPrimaryBrush}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SessionCardStyle}" Padding="24" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Accessible Areas"
                                   FontFamily="{StaticResource AppDisplayFont}"
                                   FontSize="22"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <ItemsControl ItemsSource="{Binding AccessibleAreas}" Margin="0,18,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Margin="0,5,12,0"
                                                 Fill="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Width="360" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SessionCardStyle}" Padding="24" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="Auth acceptance rules"
                               FontFamily="{StaticResource AppDisplayFont}"
                               FontSize="22"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="The live auth flow now enforces the critical acceptance criteria for M1-AUTH-001."
                               Margin="0,12,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <ItemsControl Margin="0,18,0,0">
                        <ItemsControl.Items>
                            <sys:String>Only authenticated users can open MainWindow.</sys:String>
                            <sys:String>Inactive and locked accounts are blocked at service level.</sys:String>
                            <sys:String>Role-based navigation is recalculated whenever session changes.</sys:String>
                            <sys:String>Logout clears CurrentUserService and returns to LoginWindow.</sys:String>
                        </ItemsControl.Items>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <Ellipse Width="10"
                                             Height="10"
                                             Margin="0,5,12,0"
                                             Fill="{StaticResource SuccessBrush}" />
                                    <TextBlock Text="{Binding}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
