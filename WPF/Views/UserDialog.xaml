<Window x:Class="WPF.Views.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Width="520"
        Height="600"
        MinWidth="500"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Margin="20">
        <materialDesign:Card Padding="24"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding DialogTitle}"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               FontFamily="{StaticResource AppDisplayFont}"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding DialogDescription}"
                               Margin="0,4,0,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,20,0,16"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Username"
                                 materialDesign:TextFieldAssist.HasClearButton="True" />

                        <PasswordBox PasswordChanged="OnPasswordChanged"
                                     materialDesign:HintAssist.Hint="Password"
                                     Visibility="{Binding IsPasswordRequired, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Full name"
                                 materialDesign:TextFieldAssist.HasClearButton="True" />

                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Email"
                                 materialDesign:TextFieldAssist.HasClearButton="True" />

                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Phone number"
                                 materialDesign:TextFieldAssist.HasClearButton="True" />

                        <ComboBox ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding SelectedRole}"
                                  DisplayMemberPath="DisplayName"
                                  materialDesign:HintAssist.Hint="Role" />

                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  DisplayMemberPath="DisplayName"
                                  materialDesign:HintAssist.Hint="Status" />

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Click="OnSaveClick"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnCancelClick"
                            IsCancel="True"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Close"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Cancel" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>
