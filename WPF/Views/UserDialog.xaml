<Window x:Class="WPF.Views.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}"
        Width="560"
        Height="680"
        MinWidth="520"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="28">
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding DialogTitle}"
                               FontFamily="{StaticResource AppDisplayFont}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding DialogDescription}"
                               Margin="0,8,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,24,0,24"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Username"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Visibility="{Binding IsPasswordRequired, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Password"
                                       Margin="0,16,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <PasswordBox PasswordChanged="OnPasswordChanged" />
                        </StackPanel>

                        <TextBlock Text="Full name"
                                   Margin="0,16,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Email"
                                   Margin="0,16,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Phone number"
                                   Margin="0,16,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Role"
                                   Margin="0,16,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <ComboBox ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding SelectedRole}"
                                  DisplayMemberPath="DisplayName" />

                        <TextBlock Text="Status"
                                   Margin="0,16,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  DisplayMemberPath="DisplayName" />

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Margin="0,18,0,0"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Save"
                            Click="OnSaveClick"
                            IsDefault="True"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button Content="Cancel"
                            Click="OnCancelClick"
                            IsCancel="True"
                            Style="{StaticResource GhostButtonStyle}"
                            Margin="0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
