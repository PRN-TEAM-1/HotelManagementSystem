<UserControl x:Class="WPF.Views.SectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Background="{StaticResource HeroBrush}" CornerRadius="24" Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="340" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <Border Background="#1FE5F4F8"
                                Padding="10,4"
                                CornerRadius="999"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding AccentLabel}"
                                       Foreground="{StaticResource TextInverseBrush}"
                                       FontWeight="SemiBold" />
                        </Border>

                        <TextBlock Text="{Binding Title}"
                                   Margin="0,16,0,0"
                                   FontFamily="{StaticResource AppDisplayFont}"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextInverseBrush}" />

                        <TextBlock Text="{Binding Description}"
                                   Margin="0,12,0,0"
                                   FontSize="14"
                                   Foreground="#E3F1F7"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="24,0,0,0"
                            Padding="22"
                            Background="#1AFFFFFF"
                            CornerRadius="20">
                        <StackPanel>
                            <TextBlock Text="Ready for vertical slices"
                                       Foreground="{StaticResource TextInverseBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="16" />
                            <TextBlock Text="Each feature team can now attach service-backed screens to the same shell without leaking DAO or repository calls into WPF."
                                       Margin="0,10,0,0"
                                       Foreground="#E3F1F7"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SectionCardStyle}" Padding="24" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Highlights"
                                   FontFamily="{StaticResource AppDisplayFont}"
                                   FontSize="22"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <ItemsControl ItemsSource="{Binding Highlights}" Margin="0,18,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Margin="0,5,12,0"
                                                 Fill="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Width="470" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="24" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Handoff Notes"
                                   FontFamily="{StaticResource AppDisplayFont}"
                                   FontSize="22"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <ItemsControl ItemsSource="{Binding HandoffNotes}" Margin="0,18,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Margin="0,5,12,0"
                                                 Fill="{StaticResource SuccessBrush}" />
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Width="470" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SectionCardStyle}" Padding="24" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="Tags"
                               FontFamily="{StaticResource AppDisplayFont}"
                               FontSize="22"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <ItemsControl ItemsSource="{Binding Tags}" Margin="0,18,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12"
                                        Padding="12,6"
                                        Background="{StaticResource AccentSoftBrush}"
                                        CornerRadius="999">
                                    <TextBlock Text="{Binding}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
