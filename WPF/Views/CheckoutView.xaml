<UserControl x:Class="WPF.Views.CheckoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource WindowBackgroundBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Check-Out Management"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Check-out guests and process room cleaning"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Messages Section -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <!-- Error Message -->
            <Border Background="#FFE5C8"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="×"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#856404"
                            FontSize="16" />
                </Grid>
            </Border>

            <!-- Success Message -->
            <Border Background="#D4EDDA"
                    BorderBrush="#28A745"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="#155724"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="1"
                            Command="{Binding ClearMessagesCommand}"
                            Content="×"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#155724"
                            FontSize="16" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button Command="{Binding LoadCheckoutCandidatesCommand}"
                    IsEnabled="{Binding CanEdit}"
                    Content="Refresh List"
                    Padding="12,8"
                    Background="{StaticResource ButtonPrimaryBrush}"
                    Foreground="{StaticResource TextInverseBrush}"
                    FontSize="13"
                    FontWeight="SemiBold" />
        </StackPanel>

        <!-- Candidates List -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding CheckoutCandidates}"
                  SelectedItem="{Binding SelectedCandidate}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  IsEnabled="{Binding CanEdit}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Room #" Binding="{Binding RoomNumber}" Width="80" />
                <DataGridTextColumn Header="Floor" Binding="{Binding Floor}" Width="70" />
                <DataGridTextColumn Header="Type" Binding="{Binding RoomType}" Width="100" />
                <DataGridTextColumn Header="Check-In Date" Binding="{Binding CheckInDate, StringFormat='yyyy-MM-dd'}" Width="120" />
                <DataGridTextColumn Header="Check-Out Date" Binding="{Binding CheckOutDate, StringFormat='yyyy-MM-dd'}" Width="120" />
                <DataGridTextColumn Header="Services" Binding="{Binding ServiceOrderCount}" Width="80" />
                <DataGridTextColumn Header="Service Total" Binding="{Binding ServiceOrderTotal, StringFormat='C'}" Width="120" />
                <DataGridTextColumn Header="Status" Binding="{Binding BookingDetailStatus}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Checkout Form -->
        <Border Grid.Row="4"
                Background="#F5F5F5"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="16"
                Margin="0,16,0,0"
                Visibility="{Binding SelectedCandidate, Converter={StaticResource ObjectToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Check-Out Details"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Room:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedCandidate.RoomNumber}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <TextBlock Grid.Column="2"
                               Text="Check-Out Date:"
                               VerticalAlignment="Center"
                               Margin="24,0,8,0" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding SelectedCandidate.CheckOutDate, StringFormat='yyyy-MM-dd'}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Services:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedCandidate.ServiceOrderCount}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />

                    <TextBlock Grid.Column="2"
                               Text="Service Total:"
                               VerticalAlignment="Center"
                               Margin="24,0,8,0" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding SelectedCandidate.ServiceOrderTotal, StringFormat='C'}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </Grid>

                <StackPanel Grid.Row="3" Margin="0,0,0,12">
                    <TextBlock Text="Check-Out Notes (Optional)"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8" />
                    <TextBox Text="{Binding CheckoutNote, UpdateSourceTrigger=PropertyChanged}"
                             Background="White"
                             BorderBrush="#D0D0D0"
                             BorderThickness="1"
                             Padding="10,8"
                             FontSize="12"
                             Height="60"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsEnabled="{Binding CanEdit}" />
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding CheckoutCommand}"
                            IsEnabled="{Binding CanEdit}"
                            Content="Complete Check-Out"
                            Padding="16,10"
                            Background="{StaticResource ButtonSuccessBrush}"
                            Foreground="{StaticResource TextInverseBrush}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Margin="0,0,8,0" />
                    <Button Click="OnCancelClick"
                            IsEnabled="{Binding CanEdit}"
                            Content="Cancel"
                            Padding="16,10"
                            Background="{StaticResource ButtonSecondaryBrush}"
                            Foreground="{StaticResource TextBrush}"
                            FontSize="13"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Indicator -->
        <Border Grid.Row="3"
                Background="#80000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="200" Height="4" IsIndeterminate="True" Background="#40FFFFFF" Foreground="#2196F3" />
                <TextBlock Text="Processing..." Foreground="White" FontSize="14" TextAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
