<UserControl x:Class="WPF.Views.CheckoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#FFF3D6"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource WarningBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ErrorMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="#856404"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Padding="12"
                                 Margin="0,0,0,8"
                                 Background="#DFF3E7"
                                 materialDesign:ElevationAssist.Elevation="Dp1"
                                 Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="CheckCircleOutline"
                                             Width="20"
                                             Height="20"
                                             Foreground="{StaticResource SuccessBrush}"
                                             VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SuccessMessage}"
                               Margin="8,0,8,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{StaticResource SuccessBrush}"
                               TextWrapping="Wrap" />
                    <Button Grid.Column="2"
                            Command="{Binding ClearMessagesCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                    </Button>
                </Grid>
            </materialDesign:Card>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding LoadCheckoutCandidatesCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTip="Refresh check-out list">
                            <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" />
                        </Button>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout"
                                                     Width="20"
                                                     Height="20"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Active Stays"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CheckoutCandidates}"
                              SelectedItem="{Binding SelectedCandidate}"
                              IsEnabled="{Binding CanEdit}"
                              Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Booking" Binding="{Binding BookingId}" Width="Auto" MinWidth="76" />
                            <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="Auto" MinWidth="80" />
                            <DataGridTextColumn Header="Floor" Binding="{Binding Floor}" Width="Auto" MinWidth="64" />
                            <DataGridTextColumn Header="Type" Binding="{Binding RoomType}" Width="1.4*" MinWidth="120" />
                            <DataGridTextColumn Header="Check-in" Binding="{Binding CheckInDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*" MinWidth="90" />
                            <DataGridTextColumn Header="Expected Out" Binding="{Binding CheckOutDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="*" MinWidth="90" />
                            <DataGridTextColumn Header="Services" Binding="{Binding ServiceOrderCount}" Width="Auto" MinWidth="84" />
                            <DataGridTextColumn Header="Service Total" Binding="{Binding ServiceOrderTotal, StringFormat='{}{0:N0} VND'}" Width="*" MinWidth="100" />
                            <DataGridTextColumn Header="Status" Binding="{Binding BookingDetailStatus}" Width="Auto" MinWidth="96" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2"
                                 Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="InformationOutline"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="{StaticResource AccentBrush}"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="Check-Out"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Room"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedCandidate.RoomNumber, TargetNullValue=Select a stay}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Type"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedCandidate.RoomType, TargetNullValue=-}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,12,0,0">
                            <TextBlock Text="Service Orders"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedCandidate.ServiceOrderCount, TargetNullValue=0}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,0,0">
                            <TextBlock Text="Service Total"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedCandidate.ServiceOrderTotal, StringFormat='{}{0:N0} VND', TargetNullValue=0}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                            <TextBlock Text="Actual Check-in"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding SelectedCandidate.ActualCheckInDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}', TargetNullValue=-}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <TextBox Grid.Row="2"
                             Text="{Binding CheckoutNote, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CanEdit}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="88"
                             materialDesign:HintAssist.Hint="Check-out note" />

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0">
                        <Button Command="{Binding CheckoutCommand}"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Complete check-out">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Logout"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Complete" />
                            </StackPanel>
                        </Button>
                        <Button Click="OnCancelClick"
                                IsEnabled="{Binding CanEdit}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0"
                                ToolTip="Clear selected stay">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Close"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <Border Grid.ColumnSpan="3"
                    Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="160"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}" />
                    <TextBlock Text="Loading..."
                               Margin="0,8,0,0"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
